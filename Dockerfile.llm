# Dockerfile.llm - 轻量级 llama.cpp server + 模型打包成一体化镜像
#
# 基础镜像仅 8.8MB（Alpine + 预编译 llama.cpp server）
# 支持 OpenAI 兼容 API: /v1/chat/completions
#
# 构建: docker build -f Dockerfile.llm -t tpm-app-llm .

ARG REGISTRY=docker.1ms.run/
FROM ${REGISTRY}samueltallet/alpine-llama-cpp-server:latest

# 把本地 GGUF 模型 COPY 进镜像
COPY models/Qwen3.5-0.8B-Q4_K_M.gguf /models/Qwen3.5-0.8B-Q4_K_M.gguf

# 配置
ENV LLAMA_ARG_MODEL=/models/Qwen3.5-0.8B-Q4_K_M.gguf
ENV LLAMA_ARG_ALIAS=qwen3.5
ENV LLAMA_API_KEY=not-needed
# ENV LLAMA_ARG_CTX_SIZE=1024
# ENV LLAMA_ARG_N_PREDICT=256
# 关闭思考模式（Qwen3.5 默认开启思考，CPU 上会浪费大量 token 在 <think> 上）
ENV LLAMA_ARG_REASONING=off

# 暴露端口
EXPOSE 8080
